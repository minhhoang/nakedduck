{
  "kind": "collectionType",
  "collectionName": "brands",
  "info": {
    "singularName": "brand",
    "pluralName": "brands",
    "displayName": "Brand",
    "description": "Cafe brand info"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "richtext",
      "required": true
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "required": true
    },
    "isHotBarAvailable": {
      "type": "boolean",
      "required": true,
      "default": false
    },
    "size": {
      "type": "enumeration",
      "enum": ["small", "large"],
      "required": true
    }
  }
}